---
// src/components/Testimonials.astro

const reviews = [
  {
    name: "Sarah Jenkins",
    service: "Full House Clearance",
    text: "Absolutely fantastic service. C&S cleared my late mother's house with such respect and efficiency. They arrived on time, worked incredibly hard, and left the place spotless. Highly recommended!",
    stars: 5
  },
  {
    name: "Mark T.",
    service: "Scrap Metal Collection",
    text: "Called them to get rid of a pile of old radiators and pipes after a renovation. They were here the next morning. It's great to find a fully registered carrier you can actually trust.",
    stars: 5
  },
  {
    name: "Emma & David",
    service: "Residential Moving",
    text: "Moving is stressful, but the C&S team made it look easy. They handled our furniture with real care and didn't leave a single scratch on the walls. Honest, hardworking family business.",
    stars: 5
  }
];
---

<section class="py-24 bg-[#fdfdfd] relative overflow-hidden">
  
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    
    <div class="text-center mb-16">
      <h2 class="text-4xl font-extrabold text-brand-black tracking-tight mb-4">What Our Clients Say</h2>
      <div class="w-24 h-1 bg-brand-gold mx-auto rounded"></div>
      <p class="mt-6 text-lg text-gray-600 max-w-2xl mx-auto">
        Don't just take our word for it. Here is what people across the UK have to say about our services.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      {reviews.map((review) => (
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl transition-shadow duration-300 relative">
          
          <div class="absolute top-6 right-6 text-brand-gold opacity-20">
            <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 32 32" aria-hidden="true">
              <path d="M9.352 4C4.456 7.456 1 13.12 1 19.36c0 5.088 3.072 8.064 6.624 8.064 3.36 0 5.856-2.688 5.856-5.856 0-3.168-2.208-5.472-5.088-5.472-.576 0-1.344.096-1.536.192.48-3.264 3.552-7.104 6.624-9.024L9.352 4zm16.512 0c-4.896 3.456-8.352 9.12-8.352 15.36 0 5.088 3.072 8.064 6.624 8.064 3.264 0 5.856-2.688 5.856-5.856 0-3.168-2.304-5.472-5.184-5.472-.576 0-1.248.096-1.44.192.48-3.264 3.456-7.104 6.528-9.024L25.864 4z" />
            </svg>
          </div>

          <div class="flex gap-1 mb-4">
            {[...Array(review.stars)].map(() => (
              <svg class="w-5 h-5 text-brand-gold" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <p class="text-gray-700 italic mb-6 relative z-10 leading-relaxed">
            "{review.text}"
          </p>

          <div class="mt-auto border-t border-gray-100 pt-4">
            <p class="font-bold text-gray-900">{review.name}</p>
            <p class="text-sm text-brand-gold font-medium uppercase tracking-wide mt-1">{review.service}</p>
          </div>

        </div>
      ))}
      
    </div>
  </div>
</section>