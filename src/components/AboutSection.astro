---
// src/components/AboutSection.astro
---

<section class="relative py-28 bg-[#1a1a1a] text-white overflow-hidden">
  
  <div class="absolute top-0 left-0 w-full overflow-hidden leading-none z-10 transform rotate-180 -translate-y-[1px]">
    <svg class="relative block w-full h-[60px] md:h-[120px]" preserveAspectRatio="none" viewBox="0 0 1200 120" xmlns="http://www.w3.org/2000/svg">
        <path fill="#fdfdfd" d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,119.3,192.39,101.51,235.34,89.06,278.36,73.1,321.39,56.44Z"></path>
    </svg>
  </div>

  <div class="absolute inset-0 z-0 opacity-[0.03] pointer-events-none mt-12" 
       style="background-image: repeating-linear-gradient(-45deg, rgba(255, 193, 7, 1), rgba(255, 193, 7, 1) 1px, transparent 1px, transparent 20px);">
  </div>

  <div class="relative z-20 max-w-7xl mx-auto px-6 mt-16 md:mt-24 flex flex-col lg:flex-row items-center gap-16">
    
    <div class="w-full lg:w-1/2">
      <div class="inline-block px-4 py-1.5 rounded-full bg-brand-gold/10 border border-brand-gold/20 text-brand-gold font-bold text-sm tracking-wider mb-6">
        THE C&S DIFFERENCE
      </div>
      
      <h2 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight text-gray-50">
        We care for your property <span class="text-brand-gold">as if it were our own.</span>
      </h2>
      
      <p class="text-gray-300 text-lg mb-8 leading-relaxed font-light">
        As a family-run business, our reputation is everything. Whether we are helping you move into a new home, clearing out a property, or legally disposing of scrap metal, we bring honesty, hard work, and reliability to every single job.
      </p>
      
      <ul class="space-y-4 mb-10">
        {[
          "100% Honest & Reliable Family Team",
          "Environment Agency Registered Refuse Carrier",
          "Fully Insured for Complete Peace of Mind",
          "Transparent Pricing with Zero Hidden Fees"
        ].map((item) => (
          <li class="flex items-center text-gray-200">
            <div class="w-7 h-7 rounded-full bg-brand-gold/20 flex items-center justify-center mr-4 flex-shrink-0">
              <svg class="w-4 h-4 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <span class="font-medium">{item}</span>
          </li>
        ))}
      </ul>

      <ul class="space-y-4 mb-10">
         </ul>

      <div class="mt-8">
        <button class="quote-trigger cursor-pointer bg-brand-gold hover:bg-white text-brand-black font-bold py-4 px-8 rounded shadow-[0_0_15px_rgba(255,193,7,0.3)] transition-all duration-300 transform hover:-translate-y-1 text-lg flex items-center gap-2 group">
  Get Your Free Quote
  <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
  </svg>
</button>
        <p class="text-gray-400 text-sm mt-3 font-light">No obligation, transparent pricing.</p>
      </div>
    </div>

    <div class="w-full lg:w-1/2 relative">
      
      <div class="relative rounded-2xl overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.4)] border border-white/5 group">
        <img src="https://images.unsplash.com/photo-1517048676732-d65bc937f952?auto=format&fit=crop&q=80" alt="C&S Multi Services Professional" class="w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-700 opacity-90" />
        
        <div class="absolute inset-0 bg-gradient-to-t from-[#1a1a1a]/90 to-transparent"></div>
      </div>
        
      <div class="absolute -bottom-6 -left-6 md:-left-12 z-30 bg-white text-gray-900 p-4 md:p-6 rounded-xl shadow-2xl border-l-4 border-brand-gold flex items-center gap-4 transform hover:-translate-y-2 transition-transform duration-300">
        <div class="w-12 h-12 bg-gray-50 rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-7 h-7 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 font-bold uppercase tracking-wider mb-0.5">Officially Verified</p>
          <p class="text-sm md:text-base font-extrabold leading-tight">Environment Agency<br/><span class="font-medium text-gray-700">Registered Carrier</span></p>
        </div>
      </div>

      <div class="absolute -top-10 -right-10 w-40 h-40 bg-brand-gold/10 rounded-full blur-3xl z-0 pointer-events-none"></div>
      <div class="absolute -bottom-10 -right-10 w-48 h-48 border border-brand-gold/20 rounded-full z-0 pointer-events-none"></div>

    </div>
  </div>
</section>