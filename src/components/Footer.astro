---
// src/components/FooterContact.astro
---

<footer class="bg-[#1a1a1a] text-gray-300 relative overflow-hidden">
  
  <div class="h-1.5 w-full bg-brand-gold"></div>

  <div class="max-w-7xl mx-auto px-6 py-24">
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      
      <div class="w-full h-72 md:h-96 rounded-xl overflow-hidden border border-white/10 shadow-lg relative order-2 lg:order-1 bg-[#111111]">
        
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d150449.61050851888!2d-1.6888204689617267!3d53.80608240590393!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x48793e4ada64bd99%3A0x51adbafd0213dca9!2sLeeds%2C%20UK!5e0!3m2!1sen!2sus!4v1700000000000!5m2!1sen!2sus" 
          class="absolute inset-0 w-full h-full border-0 grayscale opacity-80 hover:grayscale-0 hover:opacity-100 transition-all duration-500"
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>

      <div class="flex flex-col justify-center order-1 lg:order-2">
        <h3 class="text-3xl font-extrabold text-white mb-8">Direct Contact</h3>
        
        <div class="space-y-6 mb-8">
          <a href="tel:+447756653547" class="flex items-center text-xl hover:text-brand-gold transition-colors group">
            <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center mr-4 group-hover:bg-brand-gold/20 transition-colors">
              <svg class="w-6 h-6 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            </div>
            07756 653547
          </a>
          
          <a href="mailto:info@csmultiservices.co.uk" class="flex items-center text-xl hover:text-brand-gold transition-colors group">
            <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center mr-4 group-hover:bg-brand-gold/20 transition-colors">
              <svg class="w-6 h-6 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            info@csmultiservices.co.uk
          </a>

          <div class="flex items-center text-lg text-gray-300">
             <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center mr-4">
              <svg class="w-6 h-6 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            </div>
            <div>
              <p>Leeds, West Yorkshire</p>
              <p class="text-sm text-gray-500">Covering Castleford & surrounding UK areas</p>
            </div>
          </div>
        </div>

        <a href="https://wa.me/447756653547" target="_blank" class="inline-flex items-center justify-center self-start w-auto bg-[#25D366] hover:bg-[#1da851] text-white font-bold py-3 px-6 rounded-lg shadow-lg transition-all duration-300 transform hover:-translate-y-1 text-sm">
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Chat on WhatsApp
        </a>
      </div>

    </div>
  </div>

  <div class="bg-[#0a0a0a] border-t border-white/5 py-8">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center text-sm text-gray-500">
      <p class="mb-4 md:mb-0">© 2026 C&S Multi Services. All rights reserved.</p>
      <p>
        Designed by 
        <a href="https://digitalsparkhq.com/" target="_blank" class="text-brand-gold hover:text-white font-medium transition-colors">
          Digital Spark HQ
        </a>
      </p>
    </div>
  </div>
</footer>