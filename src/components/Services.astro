---
// src/components/Services.astro

const services = [
  {
    title: "CCTV Surveys",
    description: "State-of-the-art camera technology to inspect drains, pinpoint blockages, and identify pipe damage quickly.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>`
  },
  {
    title: "Gutter Cleans & Repairs",
    description: "Clearing out debris and repairing damaged gutters to ensure proper water flow and protect your property.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>`
  },
  {
    title: "Pump Maintenance",
    description: "Expert servicing and repair of water pumps and pump houses to prevent flooding and ensure smooth operation.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>` 
  },
  {
    title: "Root Cutting & Removal",
    description: "Safe and effective removal of invasive tree roots from drainage systems without destroying the surrounding pipes.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243 4.243 3 3 0 004.243-4.243zm0-5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z"></path>`
  },
  {
    title: "Drain Lining",
    description: "No-dig structural repairs and patch liners used to permanently seal cracked, broken, or damaged pipes.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path>`
  },
  {
    title: "Bathroom Refurbishment",
    description: "Full plumbing installations and refurbishments. From straightforward swaps to complete bathroom makeovers.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 2.25c-5.385 4.318-8 8.54-8 11.85 0 4.364 3.582 7.9 8 7.9s8-3.536 8-7.9c0-3.31-2.615-7.532-8-11.85z"></path>`
  }
];
---

<section id="services" class="relative pt-40 pb-40 bg-[#fdfdfd] overflow-hidden">
  
  <div class="absolute top-0 left-0 w-full overflow-hidden leading-none z-0 transform rotate-180 -translate-y-[1px]">
    
    <svg class="relative block w-full h-[120px] md:h-[220px] text-[#FFC107] opacity-10" preserveAspectRatio="none" viewBox="0 0 1200 120" xmlns="http://www.w3.org/2000/svg">
      <path fill="currentColor" d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,119.3,192.39,101.51,235.34,89.06,278.36,73.1,321.39,56.44Z"></path>
    </svg>
    <svg class="absolute bottom-0 left-0 block w-full h-[80px] md:h-[150px] text-[#FFC107] opacity-20" preserveAspectRatio="none" viewBox="0 0 1200 120" xmlns="http://www.w3.org/2000/svg">
      <path fill="currentColor" d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,119.3,192.39,101.51,235.34,89.06,278.36,73.1,321.39,56.44Z"></path>
    </svg>
    <svg class="absolute bottom-0 left-0 block w-full h-[40px] md:h-[80px] text-[#FFC107] opacity-40" preserveAspectRatio="none" viewBox="0 0 1200 120" xmlns="http://www.w3.org/2000/svg">
      <path fill="currentColor" d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,119.3,192.39,101.51,235.34,89.06,278.36,73.1,321.39,56.44Z"></path>
    </svg>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    
    <div class="text-center mb-20 relative">
      <h2 class="text-4xl font-extrabold text-brand-black tracking-tight mb-4 drop-shadow-sm">Our Professional Services</h2>
      <div class="w-24 h-1 bg-brand-gold mx-auto rounded shadow-[0_0_8px_rgba(255,193,7,0.6)]"></div>
    </div>

    <div class="flex flex-wrap justify-center gap-8">
      
      {services.map((service) => (
        <div class="w-full md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.5rem)] max-w-sm bg-white/95 backdrop-blur-sm border border-gray-100 p-10 pb-16 shadow-lg hover:shadow-2xl transition-all duration-500 group relative overflow-hidden text-center
                    rounded-2xl hover:rounded-tl-[3rem] hover:rounded-br-[3rem] hover:rounded-tr-xl hover:rounded-bl-xl cursor-default">
          
          <div class="absolute bottom-0 left-0 w-full h-16 text-[#FFC107] opacity-20 group-hover:opacity-40 transition-opacity duration-500 pointer-events-none">
            <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 1200 120" xmlns="http://www.w3.org/2000/svg">
               <path fill="currentColor" d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,119.3,192.39,101.51,235.34,89.06,278.36,73.1,321.39,56.44Z"></path>
            </svg>
          </div>

          <div class="absolute top-0 left-0 w-full h-1 bg-brand-gold transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-center z-10"></div>

          <div class="w-20 h-20 mx-auto rounded-2xl bg-white flex items-center justify-center mb-6 group-hover:bg-brand-gold group-hover:-rotate-3 transition-all duration-500 shadow-md relative z-10 border border-gray-100 group-hover:border-transparent">
            <svg class="w-10 h-10 text-brand-black transition-colors duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" set:html={service.icon} />
          </div>

          <h3 class="text-2xl font-bold text-gray-900 mb-4 relative z-10">{service.title}</h3>
          <p class="text-gray-600 leading-relaxed text-sm relative z-10">
            {service.description}
          </p>
        </div>
      ))}

    </div>
  </div>

  <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none z-0 translate-y-[1px]">
    <svg class="relative block w-full h-[80px] md:h-[150px] text-[#FFC107] opacity-10" preserveAspectRatio="none" viewBox="0 0 1200 120" xmlns="http://www.w3.org/2000/svg">
      <path fill="currentColor" d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,119.3,192.39,101.51,235.34,89.06,278.36,73.1,321.39,56.44Z"></path>
    </svg>
    <svg class="absolute bottom-0 left-0 block w-full h-[40px] md:h-[80px] text-[#FFC107] opacity-20" preserveAspectRatio="none" viewBox="0 0 1200 120" xmlns="http://www.w3.org/2000/svg">
      <path fill="currentColor" d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,119.3,192.39,101.51,235.34,89.06,278.36,73.1,321.39,56.44Z"></path>
    </svg>
  </div>

</section>