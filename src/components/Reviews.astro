---
// src/components/Reviews.astro
---

<section id="reviews" class="py-24 relative overflow-hidden bg-white">
  <div class="max-w-6xl mx-auto px-6 relative z-10">

    <div class="text-center mb-16">
      <h2 class="text-4xl font-extrabold text-brand-black tracking-tight mb-4">Trusted by Our Customers</h2>
      <div class="w-24 h-1 bg-brand-gold mx-auto rounded shadow-sm"></div>
      <p class="mt-6 text-lg text-gray-600 max-w-2xl mx-auto">
        Don't just take our word for it. See what our local customers have to say about our rapid response and professional service.
      </p>
    </div>

    <div class="flex justify-center items-center w-full max-w-4xl mx-auto relative group">
        <div class="absolute inset-0 bg-brand-gold/10 blur-2xl rounded-3xl group-hover:bg-brand-gold/20 transition-all duration-500"></div>

        <div class="relative bg-white shadow-xl shadow-gray-200/50 border border-gray-100 rounded-2xl p-6 w-full transform transition-transform duration-300 hover:-translate-y-1 flex justify-center items-center min-h-[150px]">
            
            <div data-tt-review-snippet="no-reviews">
                <a href="https://trustatrader.com" data-tt-trader-profile>
                    TrustATrader
                </a>
            </div>

        </div>
    </div>

  </div>
</section>

<script is:inline src="https://www.trustatrader.com/api-v3/reviews-js?trader_id=32772" defer></script>