---
// src/components/Reviews.astro

// Placeholder reviews: Ask the client for 4-5 of his best TrustATrader reviews to paste in here!
const reviews = [
  {
    name: "David H.",
    location: "Sevenoaks",
    text: "Absolutely brilliant service. Armstrong was at my property within 45 minutes of me calling. Cleared the blocked drain quickly and left everything spotless.",
  },
  {
    name: "Sarah M.",
    location: "Kent",
    text: "Highly professional and very friendly. He explained exactly what the issue was with the CCTV camera. Wouldn't hesitate to use again.",
  },
  {
    name: "James T.",
    location: "Maidstone",
    text: "A true lifesaver. Had a massive emergency with an overflowing external drain on a Sunday. Sorted it out with no fuss and a very fair price.",
  },
  {
    name: "Emma W.",
    location: "Tonbridge",
    text: "Great communication from the start. Clean, tidy worker and clearly knows his stuff when it comes to plumbing and drainage. 5 stars.",
  },
  {
    name: "Paul R.",
    location: "Sevenoaks",
    text: "Fast, efficient, and genuine. It is hard to find honest tradesmen these days, but Armstrong is top tier. Highly recommended.",
  }
];
---

<section id="reviews" class="py-24 relative overflow-hidden bg-gray-50">
  <div class="max-w-7xl mx-auto relative z-10">

    <div class="text-center mb-16 px-6">
      <h2 class="text-4xl font-extrabold text-brand-black tracking-tight mb-4">Trusted by Our Customers</h2>
      <div class="w-24 h-1 bg-brand-gold mx-auto rounded shadow-sm"></div>
      <p class="mt-6 text-lg text-gray-600 max-w-2xl mx-auto">
        Don't just take our word for it. See what our local customers have to say about our rapid response and professional service.
      </p>
    </div>

    <div class="relative flex overflow-x-hidden w-full group py-4">
      <div class="absolute inset-y-0 left-0 w-16 md:w-32 bg-gradient-to-r from-gray-50 to-transparent z-10 pointer-events-none"></div>
      <div class="absolute inset-y-0 right-0 w-16 md:w-32 bg-gradient-to-l from-gray-50 to-transparent z-10 pointer-events-none"></div>

      <div class="animate-marquee flex items-center gap-6 px-3 whitespace-nowrap group-hover:[animation-play-state:paused]">
        
        {reviews.map((review) => (
          <div class="w-[350px] md:w-[400px] shrink-0 bg-white border border-gray-100 p-8 rounded-2xl shadow-lg whitespace-normal">
            <div class="flex items-center gap-1 mb-4 text-brand-gold">
              <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            </div>
            <p class="text-gray-700 italic mb-6">"{review.text}"</p>
            <div>
              <p class="font-bold text-brand-black">{review.name}</p>
              <p class="text-sm text-gray-500">{review.location}</p>
            </div>
          </div>
        ))}

        {reviews.map((review) => (
          <div class="w-[350px] md:w-[400px] shrink-0 bg-white border border-gray-100 p-8 rounded-2xl shadow-lg whitespace-normal" aria-hidden="true">
            <div class="flex items-center gap-1 mb-4 text-brand-gold">
              <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            </div>
            <p class="text-gray-700 italic mb-6">"{review.text}"</p>
            <div>
              <p class="font-bold text-brand-black">{review.name}</p>
              <p class="text-sm text-gray-500">{review.location}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-16 flex flex-col justify-center items-center w-full">
        <p class="text-sm text-gray-500 mb-4">Read all our verified reviews on</p>
        <div data-tt-review-snippet="no-reviews">
            <a href="https://trustatrader.com" data-tt-trader-profile>
                TrustATrader
            </a>
        </div>
    </div>

  </div>
</section>

<style>
  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(calc(-50% - 0.75rem)); } /* -50% to account for the duplicated array, minus the gap */
  }
  .animate-marquee {
    animation: marquee 35s linear infinite;
    /* Pauses the scrolling when the user hovers over a review with their mouse */
    width: max-content; 
  }
</style>

<script is:inline src="https://www.trustatrader.com/api-v3/reviews-js?trader_id=32772" defer></script>