---
// src/components/Header.astro

const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '/index.html';
const isAbout = pathname.startsWith('/about');
const isContact = pathname.startsWith('/contact');

const activeClass = "font-bold text-brand-gold border-b-2 border-brand-gold pb-1";
const inactiveClass = "font-semibold text-gray-700 hover:text-brand-gold transition-colors pb-1 border-b-2 border-transparent hover:border-brand-gold/50";
---

<header class="w-full font-sans">
  
  <div class="bg-white border-b border-gray-100 text-sm py-2">
    <div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
      
      <div class="flex items-center space-x-6">
        <a href="mailto:info@csmultiservices.co.uk" class="flex items-center group">
          <svg class="w-4 h-4 text-brand-gold group-hover:text-brand-black transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          <span class="ml-2 text-gray-600 group-hover:text-brand-gold transition-colors font-medium">info@csmultiservices.co.uk</span>
        </a>
        
        <a href="tel:+447756653547" class="hidden sm:flex items-center group">
          <svg class="w-4 h-4 text-brand-gold group-hover:text-brand-black transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
          <span class="ml-2 text-gray-600 group-hover:text-brand-gold transition-colors font-medium">07756 653547</span>
        </a>
      </div>

      <div class="flex items-center space-x-4">
        <a href="https://www.facebook.com/manandvanLeedz" target="_blank" class="text-brand-gold hover:text-brand-black transition-colors" aria-label="Facebook">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
        </a>
        <a href="https://wa.me/447756653547" target="_blank" class="text-brand-gold hover:text-brand-black transition-colors" aria-label="WhatsApp">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </a>
      </div>
      
    </div>
  </div>

  <div class="bg-white shadow-sm sticky top-0 z-50 transition-all duration-300 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 py-2 flex justify-between items-center">
      
      <a href="/" class="flex items-center">
        <img src="/images/logo.png" alt="C&S Multi Services Logo" class="h-20 md:h-28 w-auto object-contain py-1" />
      </a>

      <nav class="hidden md:flex items-center space-x-8">
        <a href="/" class={isHome ? activeClass : inactiveClass}>Home</a>
        <a href="/about" class={isAbout ? activeClass : inactiveClass}>About Us</a>
        <a href="/contact" class={isContact ? activeClass : inactiveClass}>Contact</a>
        
        <button class="quote-trigger cursor-pointer bg-brand-gold hover:bg-brand-black text-black hover:text-brand-gold font-bold py-2.5 px-7 rounded shadow transition-all duration-300 transform hover:-translate-y-0.5">
          Get a Free Quote
        </button>
      </nav>

      <button id="mobile-menu-open" class="md:hidden cursor-pointer text-brand-black hover:text-brand-gold transition-colors">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
      </button>
    </div>
  </div>

</header>

<div id="mobile-menu-overlay" class="fixed inset-0 bg-[#1a1a1a]/98 backdrop-blur-md z-[60] hidden flex-col items-center justify-center opacity-0 transition-opacity duration-300">
  <button id="mobile-menu-close" class="absolute top-8 right-8 cursor-pointer text-white hover:text-brand-gold transition-all duration-300 hover:rotate-90">
    <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
  </button>
  
  <nav class="flex flex-col space-y-8 text-center text-2xl mt-20">
    <a href="/" class={isHome ? "font-bold text-brand-gold" : "text-white hover:text-brand-gold transition-colors"}>Home</a>
    <a href="/about" class={isAbout ? "font-bold text-brand-gold" : "text-white hover:text-brand-gold transition-colors"}>About Us</a>
    <a href="/contact" class={isContact ? "font-bold text-brand-gold" : "text-white hover:text-brand-gold transition-colors"}>Contact</a>
    
    <button class="quote-trigger cursor-pointer mt-8 bg-brand-gold text-brand-black font-bold py-3 px-8 rounded-lg shadow-lg">
      Get a Free Quote
    </button>
  </nav>
</div>

<div id="quote-modal-overlay" class="fixed inset-0 z-[100] hidden bg-black/80 backdrop-blur-sm flex items-center justify-center p-4 opacity-0 transition-opacity duration-300">
  <div class="bg-[#1a1a1a] rounded-2xl w-full max-w-2xl p-8 md:p-10 relative border border-white/10 shadow-2xl transform scale-95 transition-transform duration-300" id="quote-modal-content">
    
    <button id="close-quote-modal" class="absolute top-6 right-6 cursor-pointer text-gray-400 hover:text-white transition-colors">
      <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
    
    <h3 class="text-3xl font-extrabold text-white mb-2">Request a Free Quote</h3>
    <p class="text-gray-400 mb-8 text-sm">Fill out the form below and we will get back to you shortly.</p>
    
    <form class="space-y-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1">Your Name *</label>
          <input type="text" required class="w-full bg-[#111111] border border-white/10 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-brand-gold transition-colors" placeholder="John Doe">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1">Phone Number *</label>
          <input type="tel" required class="w-full bg-[#111111] border border-white/10 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-brand-gold transition-colors" placeholder="07756 653547">
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-400 mb-1">Service Required *</label>
        <select required class="w-full bg-[#111111] border border-white/10 rounded-lg px-4 py-2.5 text-gray-300 focus:outline-none focus:border-brand-gold transition-colors appearance-none cursor-pointer">
          <option value="" disabled selected>Select a Service...</option>
          <option value="removals">Removals</option>
          <option value="clearances">Clearances</option>
          <option value="scrap">Scrap Metal Collection</option>
          <option value="transport">Transport</option>
          <option value="cleaning">Cleaning Services</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-400 mb-1">Project Details</label>
        <textarea rows="3" class="w-full bg-[#111111] border border-white/10 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-brand-gold transition-colors" placeholder="Tell us what you need help with..."></textarea>
      </div>
      <button type="submit" class="cursor-pointer w-full bg-brand-gold hover:bg-white text-brand-black font-bold py-3 px-8 rounded-lg shadow-[0_0_15px_rgba(255,193,7,0.2)] transition-all duration-300 transform hover:-translate-y-1 mt-2">
        Send Message
      </button>
    </form>
  </div>
</div>

<script>
  // Mobile Menu Logic
  const mobileMenuOpen = document.getElementById('mobile-menu-open');
  const mobileMenuClose = document.getElementById('mobile-menu-close');
  const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');

  if(mobileMenuOpen && mobileMenuClose && mobileMenuOverlay) {
    mobileMenuOpen.addEventListener('click', () => {
      mobileMenuOverlay.classList.remove('hidden');
      setTimeout(() => mobileMenuOverlay.classList.remove('opacity-0'), 10);
      document.body.style.overflow = 'hidden';
    });

    mobileMenuClose.addEventListener('click', () => {
      mobileMenuOverlay.classList.add('opacity-0');
      setTimeout(() => mobileMenuOverlay.classList.add('hidden'), 300);
      document.body.style.overflow = 'auto'; 
    });
  }

  // Quote Modal Logic
  const quoteTriggers = document.querySelectorAll('.quote-trigger');
  const quoteModalOverlay = document.getElementById('quote-modal-overlay');
  const quoteModalContent = document.getElementById('quote-modal-content');
  const closeQuoteModal = document.getElementById('close-quote-modal');

  const openModal = () => {
    if(quoteModalOverlay && quoteModalContent) {
      if(mobileMenuOverlay && !mobileMenuOverlay.classList.contains('hidden')) {
         mobileMenuOverlay.classList.add('opacity-0');
         setTimeout(() => mobileMenuOverlay.classList.add('hidden'), 300);
      }
      
      quoteModalOverlay.classList.remove('hidden');
      setTimeout(() => {
        quoteModalOverlay.classList.remove('opacity-0');
        quoteModalContent.classList.remove('scale-95');
        quoteModalContent.classList.add('scale-100');
      }, 10);
      document.body.style.overflow = 'hidden';
    }
  };

  const closeModal = () => {
    if(quoteModalOverlay && quoteModalContent) {
      quoteModalOverlay.classList.add('opacity-0');
      quoteModalContent.classList.remove('scale-100');
      quoteModalContent.classList.add('scale-95');
      setTimeout(() => quoteModalOverlay.classList.add('hidden'), 300);
      document.body.style.overflow = 'auto';
    }
  };

  quoteTriggers.forEach(btn => btn.addEventListener('click', openModal));
  if(closeQuoteModal) closeQuoteModal.addEventListener('click', closeModal);
  
  if(quoteModalOverlay) {
    quoteModalOverlay.addEventListener('click', (e) => {
      if(e.target === quoteModalOverlay) closeModal();
    });
  }
</script>