---
// src/components/Gallery.astro

// Updated to match Armstrong Drainage's Facebook posts and your new image naming convention
const projects = [
  {
    title: "New Drain Line Added At Local School",
    beforeImg: "/images/before1.jpg",
    afterImg: "/images/after1.jpg",
  },
  {
    title: "Collapsed Drain Emergency Excavation & Repair",
    beforeImg: "/images/before2.jpg",
    afterImg: "/images/after2.jpg",
  },
  {
    title: "Gully Replacement",
    beforeImg: "/images/before3.jpg",
    afterImg: "/images/after3.jpg",
  },
  {
    title: "Ground Works & Digger Supply & Driver",
    beforeImg: "/images/before4.jpg",
    afterImg: "/images/after4.jpg",
  }
];
---

<section id="gallery" class="py-24 relative overflow-hidden bg-gradient-to-br from-[#ffffff] via-[#fffbf0] to-[#fff6d6]">
  
  <div class="max-w-6xl mx-auto px-6 relative z-10">
    
    <div class="text-center mb-16">
      <h2 class="text-4xl font-extrabold text-brand-black tracking-tight mb-4">Our Work Speaks for Itself</h2>
      <div class="w-24 h-1 bg-brand-gold mx-auto rounded shadow-sm"></div>
      <p class="mt-6 text-lg text-gray-600 max-w-2xl mx-auto">
        Real results from recent emergency callouts, excavations, and repairs. Slide through to see the Armstrong difference.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      
      {projects.map((project) => (
        <div class="group flex flex-col items-center">
          
          <div class="gallery-trigger relative w-full aspect-[4/3] flex rounded-2xl overflow-hidden shadow-md border border-white hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 cursor-pointer"
               data-title={project.title}
               data-before={project.beforeImg}
               data-after={project.afterImg}>
            
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 z-20 transition-colors duration-300 flex items-center justify-center pointer-events-none">
                <svg class="w-12 h-12 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300 drop-shadow-lg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" /></svg>
            </div>

            <div class="w-1/2 relative h-full overflow-hidden">
              <img src={project.beforeImg} alt="Before" class="w-full h-full object-cover grayscale-[20%] brightness-75" />
              <div class="absolute top-3 left-3 bg-brand-black/80 backdrop-blur text-white text-xs font-bold px-2 py-1 rounded uppercase tracking-wider">Before</div>
            </div>

            <div class="absolute inset-y-0 left-1/2 w-1 bg-brand-gold z-10 transform -translate-x-1/2 shadow-[0_0_10px_rgba(255,193,7,0.5)]"></div>

            <div class="w-1/2 relative h-full overflow-hidden">
              <img src={project.afterImg} alt="After" class="w-full h-full object-cover" />
              <div class="absolute top-3 right-3 bg-brand-gold text-brand-black text-xs font-bold px-2 py-1 rounded uppercase tracking-wider shadow-sm">After</div>
            </div>

          </div>

          <h3 class="text-xl font-bold text-gray-900 mt-6 text-center">{project.title}</h3>
        </div>
      ))}
      
    </div>
  </div>

  <div id="lightbox" class="fixed inset-0 z-[100] hidden bg-black/95 flex-col items-center justify-center p-4 sm:p-8 opacity-0 transition-opacity duration-300">
    
    <button id="lightbox-close" class="absolute top-6 right-6 md:top-10 md:right-10 text-white hover:text-brand-gold transition-colors z-50 p-2 cursor-pointer">
      <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <div class="w-full max-w-5xl flex flex-col items-center">
      <h3 id="lightbox-title" class="text-3xl md:text-4xl font-extrabold text-white mb-8 text-center drop-shadow-md"></h3>
      
      <div class="relative w-full aspect-[4/3] md:aspect-[16/9] flex rounded-xl overflow-hidden shadow-[0_0_40px_rgba(0,0,0,0.8)] border border-white/10">
        <div class="w-1/2 relative h-full">
          <img id="lightbox-before" src="" alt="Full Before View" class="w-full h-full object-cover grayscale-[15%] brightness-[0.85]" />
          <div class="absolute top-4 left-4 md:top-6 md:left-6 bg-brand-black/90 text-white text-sm md:text-lg font-bold px-4 py-2 rounded uppercase tracking-wider">Before</div>
        </div>
        
        <div class="absolute inset-y-0 left-1/2 w-1.5 md:w-2 bg-brand-gold z-10 transform -translate-x-1/2 shadow-[0_0_20px_rgba(255,193,7,0.8)]"></div>
        
        <div class="w-1/2 relative h-full">
          <img id="lightbox-after" src="" alt="Full After View" class="w-full h-full object-cover" />
          <div class="absolute top-4 right-4 md:top-6 md:right-6 bg-brand-gold text-brand-black text-sm md:text-lg font-bold px-4 py-2 rounded uppercase tracking-wider shadow-lg">After</div>
        </div>
      </div>
    </div>
  </div>

</section>

<script>
  const triggers = document.querySelectorAll('.gallery-trigger');
  const lightbox = document.getElementById('lightbox');
  const closeBtn = document.getElementById('lightbox-close');
  const lbTitle = document.getElementById('lightbox-title');
  const lbBefore = document.getElementById('lightbox-before');
  const lbAfter = document.getElementById('lightbox-after');

  // Open Lightbox
  triggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      if(lbTitle && lbBefore && lbAfter && lightbox) {
          lbTitle.textContent = trigger.getAttribute('data-title');
          lbBefore.setAttribute('src', trigger.getAttribute('data-before') || '');
          lbAfter.setAttribute('src', trigger.getAttribute('data-after') || '');
          
          lightbox.classList.remove('hidden');
          setTimeout(() => {
            lightbox.classList.remove('opacity-0');
          }, 10);
      }
    });
  });

  // Close Lightbox Function
  const closeLightbox = () => {
    if(lightbox) {
        lightbox.classList.add('opacity-0');
        setTimeout(() => {
          lightbox.classList.add('hidden');
        }, 300); 
    }
  };

  if(closeBtn) closeBtn.addEventListener('click', closeLightbox);
  
  if(lightbox) {
      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox) {
          closeLightbox();
        }
      });
  }
</script>