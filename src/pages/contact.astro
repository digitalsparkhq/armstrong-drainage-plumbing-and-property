---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
import FooterContact from '../components/FooterContact.astro';
---

<Layout title="Contact Us">
  <main>
    
    <section class="relative bg-[#1a1a1a] py-24 md:py-32 overflow-hidden">
      <div class="absolute inset-0 z-0 opacity-[0.03] pointer-events-none" 
           style="background-image: repeating-linear-gradient(-45deg, rgba(255, 193, 7, 1), rgba(255, 193, 7, 1) 1px, transparent 1px, transparent 20px);">
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
        <h1 class="text-5xl md:text-6xl font-extrabold text-white mb-6 tracking-tight drop-shadow-lg">
          Get in <span class="text-brand-gold">Touch</span>
        </h1>
        <p class="text-xl text-gray-300 max-w-2xl mx-auto font-light leading-relaxed">
          Ready to get started? Contact our family team today for a transparent, no-obligation quote. We are here to help.
        </p>
      </div>

      <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none z-20 translate-y-[1px]">
        <svg class="relative block w-full h-[40px] md:h-[80px]" preserveAspectRatio="none" viewBox="0 0 1200 120" xmlns="http://www.w3.org/2000/svg">
            <path fill="#fdfdfd" d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,119.3,192.39,101.51,235.34,89.06,278.36,73.1,321.39,56.44Z"></path>
        </svg>
      </div>
    </section>

    <section class="py-20 bg-[#fdfdfd] relative">
      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16">
        
        <div class="flex flex-col space-y-8">
          
          <div>
            <h2 class="text-3xl font-extrabold text-brand-black mb-4">We'd love to hear from you</h2>
            <p class="text-gray-600 mb-8 leading-relaxed">
              Whether you need a full property clearance, secure transport, or a quick scrap metal collection, reach out to us directly or fill in the form.
            </p>
          </div>

          <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex items-start group hover:shadow-md transition-shadow">
            <div class="w-14 h-14 rounded-full bg-gray-50 flex items-center justify-center mr-6 group-hover:bg-brand-gold/20 transition-colors flex-shrink-0">
              <svg class="w-7 h-7 text-brand-black group-hover:text-brand-gold transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            </div>
            <div>
              <p class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-1">Call Us Directly</p>
              <a href="tel:+447756653547" class="text-xl font-bold text-brand-black hover:text-brand-gold transition-colors">07756 653547</a>
            </div>
          </div>

          <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex items-start group hover:shadow-md transition-shadow">
            <div class="w-14 h-14 rounded-full bg-gray-50 flex items-center justify-center mr-6 group-hover:bg-brand-gold/20 transition-colors flex-shrink-0">
              <svg class="w-7 h-7 text-brand-black group-hover:text-brand-gold transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <div>
              <p class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-1">Email Address</p>
              <a href="mailto:info@csmultiservices.co.uk" class="text-xl font-bold text-brand-black hover:text-brand-gold transition-colors">info@csmultiservices.co.uk</a>
            </div>
          </div>

          <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex items-start group hover:shadow-md transition-shadow">
            <div class="w-14 h-14 rounded-full bg-gray-50 flex items-center justify-center mr-6 group-hover:bg-brand-gold/20 transition-colors flex-shrink-0">
              <svg class="w-7 h-7 text-brand-black group-hover:text-brand-gold transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            </div>
            <div>
              <p class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-1">Operating Area</p>
              <p class="text-lg font-bold text-brand-black">Leeds, West Yorkshire</p>
              <p class="text-gray-600 mt-1">Covering Castleford & surrounding areas across the UK.</p>
            </div>
          </div>

        </div>

        <div class="bg-white p-8 md:p-10 rounded-3xl shadow-2xl border border-gray-100 relative">
          <div class="absolute top-0 left-0 w-full h-2 bg-brand-gold rounded-t-3xl"></div>
          
          <h3 class="text-2xl font-extrabold text-brand-black mb-6">Request a Free Quote</h3>
          
          <form class="space-y-5">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-bold text-gray-700 mb-1.5">Your Name *</label>
                <input type="text" required class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-gold focus:border-transparent transition-all" placeholder="John Doe">
              </div>
              <div>
                <label class="block text-sm font-bold text-gray-700 mb-1.5">Phone Number *</label>
                <input type="tel" required class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-gold focus:border-transparent transition-all" placeholder="07756 653547">
              </div>
            </div>
            
            <div>
              <label class="block text-sm font-bold text-gray-700 mb-1.5">Email Address</label>
              <input type="email" class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-gold focus:border-transparent transition-all" placeholder="info@example.com">
            </div>

            <div>
              <label class="block text-sm font-bold text-gray-700 mb-1.5">Service Required *</label>
              <select required class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-gold focus:border-transparent transition-all appearance-none cursor-pointer">
                <option value="" disabled selected>Select a Service...</option>
                <option value="removals">Removals</option>
                <option value="clearances">Clearances</option>
                <option value="scrap">Scrap Metal Collection</option>
                <option value="transport">Transport</option>
                <option value="cleaning">Cleaning Services</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-bold text-gray-700 mb-1.5">Project Details</label>
              <textarea rows="5" class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-gold focus:border-transparent transition-all" placeholder="Tell us what you need help with (e.g., amount of scrap, size of house)..."></textarea>
            </div>

            <button type="submit" class="w-full bg-brand-gold hover:bg-brand-black text-brand-black hover:text-white font-bold py-4 px-8 rounded-lg shadow-md transition-all duration-300 transform hover:-translate-y-1 mt-4">
              Send Message
            </button>
          </form>
        </div>

      </div>
    </section>

    <FooterContact />
    
  </main>
</Layout>