---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us">
  <main>
    
    <section class="relative bg-[#1a1a1a] py-24 md:py-32 overflow-hidden">
      <div class="absolute inset-0 z-0 opacity-[0.03] pointer-events-none" 
           style="background-image: repeating-linear-gradient(-45deg, rgba(255, 193, 7, 1), rgba(255, 193, 7, 1) 1px, transparent 1px, transparent 20px);">
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
        <h1 class="text-5xl md:text-6xl font-extrabold text-white mb-6 tracking-tight drop-shadow-lg">
          Get in <span class="text-brand-gold">Touch</span>
        </h1>
        <p class="text-xl text-gray-300 max-w-2xl mx-auto font-light leading-relaxed">
          Need an emergency callout or a custom quote? Contact our local experts today. We are available 24/7 to solve your drainage and plumbing issues.
        </p>
      </div>

      <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none z-20 translate-y-[1px]">
        <svg class="relative block w-full h-[40px] md:h-[80px]" preserveAspectRatio="none" viewBox="0 0 1200 120" xmlns="http://www.w3.org/2000/svg">
            <path fill="#fdfdfd" d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,119.3,192.39,101.51,235.34,89.06,278.36,73.1,321.39,56.44Z"></path>
        </svg>
      </div>
    </section>

    <section class="py-20 bg-[#fdfdfd] relative">
      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16">
        
        <div class="flex flex-col space-y-8">
          
          <div>
            <h2 class="text-3xl font-extrabold text-brand-black mb-4">We're ready to help</h2>
            <p class="text-gray-600 mb-8 leading-relaxed">
              Whether you are dealing with a blocked drain, need a CCTV survey, or require our tanker for severe flooding, reach out directly or fill in the form.
            </p>
          </div>

          <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex items-start group hover:shadow-md transition-shadow">
            <div class="w-14 h-14 rounded-full bg-gray-50 flex items-center justify-center mr-6 group-hover:bg-brand-gold/20 transition-colors flex-shrink-0">
              <svg class="w-7 h-7 text-brand-black group-hover:text-brand-gold transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            </div>
            <div>
              <p class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-1">Call Us Directly (24/7)</p>
              <a href="tel:+447801490371" class="text-xl font-bold text-brand-black hover:text-brand-gold transition-colors">07801 490371</a>
            </div>
          </div>

          <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex items-start group hover:shadow-md transition-shadow">
            <div class="w-14 h-14 rounded-full bg-gray-50 flex items-center justify-center mr-6 group-hover:bg-brand-gold/20 transition-colors flex-shrink-0">
              <svg class="w-7 h-7 text-brand-black group-hover:text-brand-gold transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <div>
              <p class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-1">Email Address</p>
              <a href="mailto:armstrongdrainage@yahoo.com" class="text-xl font-bold text-brand-black hover:text-brand-gold transition-colors break-all">armstrongdrainage@yahoo.com</a>
            </div>
          </div>

          <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex items-start group hover:shadow-md transition-shadow">
            <div class="w-14 h-14 rounded-full bg-gray-50 flex items-center justify-center mr-6 group-hover:bg-brand-gold/20 transition-colors flex-shrink-0">
              <svg class="w-7 h-7 text-brand-black group-hover:text-brand-gold transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            </div>
            <div>
              <p class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-1">Operating Area</p>
              <p class="text-lg font-bold text-brand-black">TN15 0DJ, Sevenoaks</p>
              <p class="text-gray-600 mt-1">Covering the local and surrounding areas.</p>
            </div>
          </div>

        </div>

        <div class="bg-white p-8 md:p-10 rounded-3xl shadow-2xl border border-gray-100 relative">
          <div class="absolute top-0 left-0 w-full h-2 bg-brand-gold rounded-t-3xl"></div>
          
          <h3 class="text-2xl font-extrabold text-brand-black mb-2">Request a Free Quote</h3>
          <p class="text-gray-500 mb-6 text-sm">We'll get straight back to you via WhatsApp.</p>
          
          <form id="contact-page-whatsapp-form" class="space-y-5">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-bold text-gray-700 mb-1.5">Your Name *</label>
                <input id="pg-name" type="text" required class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-gold focus:border-transparent transition-all" placeholder="John Doe">
              </div>
              <div>
                <label class="block text-sm font-bold text-gray-700 mb-1.5">Phone Number *</label>
                <input id="pg-phone" type="tel" required class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-gold focus:border-transparent transition-all" placeholder="07801 490371">
              </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-bold text-gray-700 mb-1.5">Email Address</label>
                <input id="pg-email" type="email" class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-gold focus:border-transparent transition-all" placeholder="Optional">
              </div>
              <div>
                <label class="block text-sm font-bold text-gray-700 mb-1.5">Postcode / Pincode *</label>
                <input id="pg-postcode" type="text" required class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-gold focus:border-transparent transition-all" placeholder="e.g. TN15 0DJ">
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-bold text-gray-700 mb-1.5">Service Required *</label>
                <select id="pg-service" required class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-gold focus:border-transparent transition-all appearance-none cursor-pointer">
                  <option value="" disabled selected>Select a Service...</option>
                  <option value="Drain Blockages">Drain Blockages</option>
                  <option value="CCTV Surveys">CCTV Surveys</option>
                  <option value="Gutter Cleans & Repairs">Gutter Cleans & Repairs</option>
                  <option value="Pump Maintenance">Pump Maintenance</option>
                  <option value="Root Cutting & Removal">Root Cutting & Removal</option>
                  <option value="Drain Lining">Drain Lining</option>
                  <option value="Bathroom Refurbishment">Bathroom Refurbishment</option>
                  <option value="General Plumbing">General Plumbing / Other</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-bold text-gray-700 mb-1.5">Timescale *</label>
                <select id="pg-timescale" required class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-gold focus:border-transparent transition-all appearance-none cursor-pointer">
                  <option value="" disabled selected>When do you need this?</option>
                  <option value="Immediate / Emergency">Immediate / Emergency</option>
                  <option value="Within a week">Within a week</option>
                  <option value="Within two weeks">Within two weeks</option>
                  <option value="Flexible">Flexible</option>
                </select>
              </div>
            </div>

            <div>
              <label class="block text-sm font-bold text-gray-700 mb-1.5">Project Details</label>
              <textarea id="pg-details" rows="4" class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-gold focus:border-transparent transition-all" placeholder="Tell us what you need help with (e.g., blocked drain, flood water)..."></textarea>
            </div>

            <button type="submit" class="w-full bg-[#25D366] hover:bg-[#1da851] text-white font-bold py-4 px-8 rounded-lg shadow-md transition-all duration-300 transform hover:-translate-y-1 mt-4 flex items-center justify-center gap-2 cursor-pointer">
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Send Message via WhatsApp
            </button>
          </form>
        </div>

      </div>
    </section>
    
  </main>
</Layout>

<script>
  // Dedicated WhatsApp Form Submission Logic for the Contact Page
  const pageForm = document.getElementById('contact-page-whatsapp-form') as HTMLFormElement;

  if (pageForm) {
    pageForm.addEventListener('submit', (e) => {
      e.preventDefault(); 

      // Grab values from inputs safely
      const name = (document.getElementById('pg-name') as HTMLInputElement)?.value || '';
      const phone = (document.getElementById('pg-phone') as HTMLInputElement)?.value || '';
      const email = (document.getElementById('pg-email') as HTMLInputElement)?.value || 'Not provided';
      const postcode = (document.getElementById('pg-postcode') as HTMLInputElement)?.value || '';
      const service = (document.getElementById('pg-service') as HTMLSelectElement)?.value || '';
      const timescale = (document.getElementById('pg-timescale') as HTMLSelectElement)?.value || '';
      const details = (document.getElementById('pg-details') as HTMLTextAreaElement)?.value || 'None';

      // Format the WhatsApp message specifically for the Contact Page
      const message = `*New Lead via Contact Page* 📋\n\n*Name:* ${name}\n*Phone:* ${phone}\n*Email:* ${email}\n*Postcode:* ${postcode}\n*Service Needed:* ${service}\n*Timescale:* ${timescale}\n*Details:* ${details}`;

      // Encode for URL and open WhatsApp (targeting the correct Armstrong Drainage number)
      const whatsappUrl = `https://wa.me/447801490371?text=${encodeURIComponent(message)}`;
      window.open(whatsappUrl, '_blank');

      // Reset the form so it's ready if they come back
      pageForm.reset();
    });
  }
</script>