---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro'; // Using the main footer with the form
---

<Layout title="About Us">
  <main>
    
    <section class="relative bg-[#1a1a1a] py-24 md:py-32 overflow-hidden">
      <div class="absolute inset-0 z-0 opacity-[0.03] pointer-events-none" 
           style="background-image: repeating-linear-gradient(-45deg, rgba(255, 193, 7, 1), rgba(255, 193, 7, 1) 1px, transparent 1px, transparent 20px);">
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
        <div class="inline-block px-4 py-1.5 rounded-full bg-brand-gold/10 border border-brand-gold/20 text-brand-gold font-bold text-sm tracking-wider mb-6">
          OUR STORY
        </div>
        <h1 class="text-5xl md:text-6xl font-extrabold text-white mb-6 tracking-tight drop-shadow-lg">
          More than just a <span class="text-brand-gold">business.</span>
        </h1>
        <p class="text-xl text-gray-300 max-w-2xl mx-auto font-light leading-relaxed">
          We are a proudly family-run team based in Leeds, dedicated to bringing honest, hardworking values to the removal and clearance industry.
        </p>
      </div>

      <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none z-20 translate-y-[1px]">
        <svg class="relative block w-full h-[40px] md:h-[80px]" preserveAspectRatio="none" viewBox="0 0 1200 120" xmlns="http://www.w3.org/2000/svg">
            <path fill="#fdfdfd" d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,119.3,192.39,101.51,235.34,89.06,278.36,73.1,321.39,56.44Z"></path>
        </svg>
      </div>
    </section>

    <section class="py-20 bg-[#fdfdfd] relative">
      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        
        <div class="relative rounded-2xl overflow-hidden shadow-2xl border border-gray-100 group">
          <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&q=80" alt="C&S Multi Services Team" class="w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-700" />
          
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
          
          <div class="absolute bottom-6 left-6 right-6">
            <p class="text-white font-bold text-xl drop-shadow-md">Based in West Yorkshire</p>
            <p class="text-brand-gold font-medium">Covering Castleford & beyond</p>
          </div>
        </div>

        <div>
          <h2 class="text-3xl font-extrabold text-brand-black mb-6">Built on hard work and reputation.</h2>
          <div class="w-20 h-1 bg-brand-gold mb-8 rounded"></div>
          
          <div class="space-y-6 text-gray-600 leading-relaxed text-lg">
            <p>
              When we started C&S Multi Services, we noticed a massive gap in the market. People were tired of dealing with unreliable contractors, hidden fees, and fly-tippers damaging the reputation of the waste and removals industry.
            </p>
            <p>
              We wanted to do things differently. As a family, we put our own name and reputation on the line with every single job. Whether we are moving a single sofa, clearing out a commercial scrap yard, or doing a deep post-tenancy clean, we treat your property with the exact same respect we would treat our own.
            </p>
            <p>
              Today, we are proud to be fully <strong class="text-gray-900">Environment Agency Registered Refuse Carriers</strong>. This means when you hand your scrap or clearance waste over to us, you have total peace of mind knowing it will be disposed of legally, ethically, and responsibly.
            </p>
          </div>
        </div>

      </div>
    </section>

    <section class="py-24 bg-white border-t border-gray-100">
      <div class="max-w-7xl mx-auto px-6">
        
        <div class="text-center mb-16">
          <h2 class="text-3xl font-extrabold text-brand-black mb-4">The C&S Difference</h2>
          <p class="text-gray-600 max-w-2xl mx-auto">This is what you can expect every time you hire us.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          
          <div class="p-8 rounded-2xl bg-gray-50 border border-gray-100 text-center hover:shadow-lg transition-shadow duration-300 group">
            <div class="w-16 h-16 mx-auto bg-white rounded-full flex items-center justify-center shadow-sm mb-6 group-hover:bg-brand-gold transition-colors duration-300">
              <svg class="w-8 h-8 text-brand-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.514"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Honest Pricing</h3>
            <p class="text-gray-600 text-sm leading-relaxed">No hidden fees, no last-minute surprises. We provide transparent, upfront quotes for all our services.</p>
          </div>

          <div class="p-8 rounded-2xl bg-gray-50 border border-gray-100 text-center hover:shadow-lg transition-shadow duration-300 group">
            <div class="w-16 h-16 mx-auto bg-white rounded-full flex items-center justify-center shadow-sm mb-6 group-hover:bg-brand-gold transition-colors duration-300">
              <svg class="w-8 h-8 text-brand-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Fully Registered</h3>
            <p class="text-gray-600 text-sm leading-relaxed">We are officially registered with the Environment Agency. Your property and waste are in safe, legal hands.</p>
          </div>

          <div class="p-8 rounded-2xl bg-gray-50 border border-gray-100 text-center hover:shadow-lg transition-shadow duration-300 group">
            <div class="w-16 h-16 mx-auto bg-white rounded-full flex items-center justify-center shadow-sm mb-6 group-hover:bg-brand-gold transition-colors duration-300">
              <svg class="w-8 h-8 text-brand-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Family Run</h3>
            <p class="text-gray-600 text-sm leading-relaxed">When you hire us, you're hiring a dedicated family team. We care deeply about our local community and our reputation.</p>
          </div>

        </div>
      </div>
    </section>

    <Footer />
    
  </main>
</Layout>