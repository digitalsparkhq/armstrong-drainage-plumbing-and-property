---
// src/layouts/Layout.astro
import '../styles/global.css';
import Header from '../components/Header.astro';
import QuoteModal from '../components/QuoteModal.astro';
import Footer from '../components/Footer.astro';

// FIXED: Accept both title and description as properties
const { title, description } = Astro.props;

// SEO Logic: Use the exact target keyword string for the homepage title
const pageTitle = title === 'Home' 
  ? 'Armstrong Drainage | Blocked Drain Clearing in Sevenoaks & Kent' 
  : `${title} - Armstrong Drainage`;

// SEO Logic: Set a fallback description just in case a page forgets to include one
const defaultDescription = "Professional drainage services in Sevenoaks and Kent. Specializing in fast relief for blocked drains, toilets, sinks, and external blockages.";
const pageDescription = description || defaultDescription;

// Google Local Business Schema Markup
const schema = {
  "@context": "https://schema.org",
  "@type": "Plumber",
  "name": "Armstrong Drainage, Plumbing and Property Maintenance",
  "url": "https://armstrongdrainage.co.uk", 
  "image": "/images/618445594_1514886387309700_7527527295680085472_n-removebg-preview.png",
  "telephone": "+447801490371",
  "email": "armstrongdrainage@yahoo.com",
  "address": {
    "@type": "PostalAddress", 
    "streetAddress": "Sevenoaks",
    "addressLocality": "Sevenoaks",
    "addressRegion": "Kent",
    "postalCode": "TN15 0DJ",
    "addressCountry": "UK"
  },
  "areaServed": ["Sevenoaks", "Kent"],
  "priceRange": "££",
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"
    ],
    "opens": "00:00",
    "closes": "23:59"
  }
};
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <meta name="description" content={pageDescription} />
    
    <title>{pageTitle}</title>

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans antialiased">
    <Header />
    
    <slot /> 
    
    <QuoteModal />
    <Footer />
  </body>
</html>